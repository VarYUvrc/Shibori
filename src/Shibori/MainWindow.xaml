<Window x:Class="Shibori.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shibori" Height="390" Width="620" MinHeight="280" MinWidth="520"
        WindowStartupLocation="CenterScreen" Background="#FAFAFA">
  <Window.Resources>
    <Style x:Key="ConnectionToggle" TargetType="ToggleButton">
      <Setter Property="Width" Value="42"/><Setter Property="Height" Value="24"/>
      <Setter Property="Background" Value="#D1D5DB"/><Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Template">
        <Setter.Value><ControlTemplate TargetType="ToggleButton">
          <Border x:Name="Track" Background="{TemplateBinding Background}" CornerRadius="12">
            <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="White" HorizontalAlignment="Left" Margin="3"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True"><Setter TargetName="Track" Property="Background" Value="#22C55E"/><Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/></Trigger>
            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Track" Property="Opacity" Value="0.45"/></Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate></Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="FlatIconButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent"/><Setter Property="BorderBrush" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>
  </Window.Resources>
  <Grid Margin="22">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
    <Grid Margin="0,0,0,14">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <TextBlock Text="Shibori" FontSize="26" FontWeight="SemiBold" Foreground="#202124" VerticalAlignment="Center"/>
      <Button x:Name="UpdateButton" Grid.Column="1" Visibility="Collapsed" Click="Update_Click" Margin="0,0,8,0" Padding="10,6"/>
      <Button x:Name="InfoButton" Grid.Column="2" Content="ⓘ" FontSize="18" Width="32" Height="32" Padding="0" Click="About_Click" Style="{StaticResource FlatIconButton}" ToolTip="バージョン情報"/>
    </Grid>
    <Border Grid.Row="1" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="12" Background="White">
      <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid.ColumnDefinitions><ColumnDefinition Width="64"/><ColumnDefinition Width="64"/><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/><ColumnDefinition Width="115"/></Grid.ColumnDefinitions>
        <TextBlock Text="接続" FontWeight="SemiBold" Foreground="#6B7280" Margin="8,0,0,10"/>
        <TextBlock Grid.Column="1" Text="メイン" FontWeight="SemiBold" Foreground="#6B7280" Margin="8,0,0,10"/>
        <TextBlock Grid.Column="2" Text="名前" FontWeight="SemiBold" Foreground="#6B7280" Margin="8,0,0,10"/>
        <TextBlock Grid.Column="3" Text="解像度" FontWeight="SemiBold" Foreground="#6B7280" Margin="8,0,0,10"/>
        <TextBlock Grid.Column="4" Text="識別子" FontWeight="SemiBold" Foreground="#6B7280" Margin="8,0,0,10"/>
        <ScrollViewer Grid.Row="1" Grid.ColumnSpan="5" VerticalScrollBarVisibility="Auto">
          <ItemsControl x:Name="MonitorList">
            <ItemsControl.ItemTemplate><DataTemplate>
              <Grid Height="32" Margin="0,0,0,8">
                <Grid.ColumnDefinitions><ColumnDefinition Width="64"/><ColumnDefinition Width="64"/><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/><ColumnDefinition Width="115"/></Grid.ColumnDefinitions>
                <ToggleButton Tag="{Binding}" IsChecked="{Binding IsConnected, Mode=OneWay}" Style="{StaticResource ConnectionToggle}" Click="ConnectionToggle_Click" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <CheckBox Grid.Column="1" Tag="{Binding}" IsChecked="{Binding IsPrimary, Mode=OneWay}" IsEnabled="{Binding IsConnected}" Click="MainCheckBox_Click" HorizontalAlignment="Left" VerticalAlignment="Center" Height="24" Padding="0" Margin="10,0,0,0" VerticalContentAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding FriendlyName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="8,0" ToolTip="{Binding FriendlyName}"/>
                <TextBlock Grid.Column="3" Text="{Binding Resolution}" Foreground="#6B7280" VerticalAlignment="Center" Margin="8,0"/>
                <TextBlock Grid.Column="4" Text="{Binding DeviceName}" Foreground="#9CA3AF" FontSize="11" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="8,0" ToolTip="{Binding DeviceName}"/>
              </Grid>
            </DataTemplate></ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>
    <Grid x:Name="BusyOverlay" Grid.RowSpan="2" Visibility="Collapsed" Panel.ZIndex="20" Background="#99FFFFFF">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="220">
        <ProgressBar IsIndeterminate="True" Height="5" Margin="0,0,0,10"/>
        <TextBlock Text="アップデート中…" HorizontalAlignment="Center" Foreground="#374151"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
