<Window x:Class="Shibori.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shibori" Height="410" Width="650" MinHeight="300" MinWidth="540"
        WindowStartupLocation="CenterScreen" Background="#FAFAFA">
  <Window.Resources>
    <Style TargetType="CheckBox">
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="Padding" Value="8"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>
    <Style x:Key="FlatIconButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>
  </Window.Resources>
  <Grid Margin="28">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
    <Grid Margin="0,0,0,18">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <TextBlock Text="Shibori" FontSize="28" FontWeight="SemiBold" Foreground="#202124" VerticalAlignment="Center"/>
      <Button x:Name="UpdateButton" Grid.Column="1" Visibility="Collapsed" Click="Update_Click" Margin="0,0,8,0" Padding="10,6"/>
      <Button x:Name="InfoButton" Grid.Column="2" Content="ⓘ" FontSize="18" Width="32" Height="32" Padding="0" Margin="0" Click="About_Click" Style="{StaticResource FlatIconButton}" ToolTip="バージョン情報"/>
    </Grid>
    <Border Grid.Row="1" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="14" Background="White">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl x:Name="MonitorList">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <CheckBox Tag="{Binding}" IsChecked="{Binding IsConnected}" Click="Monitor_Click">
                <Grid Width="550">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="{Binding FriendlyName}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding DeviceName}" Foreground="#9CA3AF" FontSize="12"/>
                    <TextBlock Text="{Binding Resolution}" Foreground="#6B7280" Margin="0,3,0,0"/>
                  </StackPanel>
                  <ComboBox Grid.Column="1" Tag="{Binding}" Width="92" Margin="12,0,0,0" VerticalAlignment="Center"
                            SelectedValue="{Binding Role, Mode=OneWay}" SelectedValuePath="Content" SelectionChanged="Role_SelectionChanged"
                            IsEnabled="{Binding IsConnected}">
                    <ComboBoxItem Content="メイン"/>
                    <ComboBoxItem Content="サブ"/>
                  </ComboBox>
                </Grid>
              </CheckBox>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>
  </Grid>
</Window>
