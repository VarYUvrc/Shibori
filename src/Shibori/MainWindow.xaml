<Window x:Class="Shibori.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shibori" Height="390" Width="520" MinHeight="280" MinWidth="420"
        WindowStartupLocation="CenterScreen" Background="#FAFAFA">
  <Window.Resources>
    <Style TargetType="CheckBox">
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="Padding" Value="8"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>
    <Style x:Key="PrimaryToggle" TargetType="ToggleButton">
      <Setter Property="Width" Value="42"/>
      <Setter Property="Height" Value="24"/>
      <Setter Property="Background" Value="#D1D5DB"/>
      <Setter Property="BorderBrush" Value="#D1D5DB"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border x:Name="Track" Background="{TemplateBinding Background}" CornerRadius="12">
              <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="White" HorizontalAlignment="Left" Margin="3"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Track" Property="Background" Value="#22C55E"/>
                <Setter TargetName="Track" Property="BorderBrush" Value="#22C55E"/>
                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Track" Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="FlatIconButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>
  </Window.Resources>
  <Grid Margin="22">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
    <Grid Margin="0,0,0,14">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <TextBlock Text="Shibori" FontSize="26" FontWeight="SemiBold" Foreground="#202124" VerticalAlignment="Center"/>
      <Button x:Name="UpdateButton" Grid.Column="1" Visibility="Collapsed" Click="Update_Click" Margin="0,0,8,0" Padding="10,6"/>
      <Button x:Name="InfoButton" Grid.Column="2" Content="ⓘ" FontSize="18" Width="32" Height="32" Padding="0" Margin="0" Click="About_Click" Style="{StaticResource FlatIconButton}" ToolTip="バージョン情報"/>
    </Grid>
    <Border Grid.Row="1" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="10" Background="White">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl x:Name="MonitorList">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <CheckBox Tag="{Binding}" IsChecked="{Binding IsConnected}" Click="Monitor_Click">
                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="{Binding FriendlyName}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding DeviceName}" Foreground="#9CA3AF" FontSize="12"/>
                    <TextBlock Text="{Binding Resolution}" Foreground="#6B7280" Margin="0,3,0,0"/>
                  </StackPanel>
                  <ToggleButton Grid.Column="1" Tag="{Binding}" IsChecked="{Binding IsPrimary, Mode=OneWay}"
                                IsEnabled="{Binding IsConnected}" Style="{StaticResource PrimaryToggle}"
                                ToolTip="メインモニターに設定" Click="PrimaryToggle_Click"/>
                </Grid>
              </CheckBox>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>
  </Grid>
</Window>
