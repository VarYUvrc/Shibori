<Window x:Class="Shibori.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shibori" Height="520" Width="650" MinHeight="420" MinWidth="540"
        WindowStartupLocation="CenterScreen" Background="#FAFAFA">
  <Window.Resources>
    <Style TargetType="CheckBox"><Setter Property="FontSize" Value="15"/><Setter Property="Padding" Value="8"/><Setter Property="Margin" Value="0,0,0,8"/></Style>
    <Style TargetType="Button"><Setter Property="Padding" Value="14,8"/><Setter Property="Margin" Value="0,0,8,0"/></Style>
  </Window.Resources>
  <Grid Margin="28">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <StackPanel><TextBlock Text="Shibori" FontSize="28" FontWeight="SemiBold" Foreground="#202124"/><TextBlock Text="使わないモニターを一時停止" Margin="0,4,0,0" Foreground="#6B7280"/></StackPanel>
    <TextBlock Grid.Row="1" Text="チェックあり＝接続中。チェックを外すと切断します。切断中のモニターは一覧から消えません。" Margin="0,24,0,12" Foreground="#4B5563" TextWrapping="Wrap"/>
    <Border Grid.Row="2" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="14" Background="White">
      <ScrollViewer VerticalScrollBarVisibility="Auto"><ItemsControl x:Name="MonitorList"><ItemsControl.ItemTemplate><DataTemplate>
        <CheckBox Tag="{Binding}" IsChecked="{Binding IsConnected}" Click="Monitor_Click">
          <Grid Width="530"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel><TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold"/><TextBlock Text="{Binding Resolution}" Foreground="#6B7280" Margin="0,3,0,0"/><TextBlock Text="{Binding Status}" Foreground="#6B7280" Margin="0,3,0,0"/></StackPanel>
            <TextBlock Grid.Column="1" Text="{Binding Role}" Foreground="#6B7280" VerticalAlignment="Center"/>
          </Grid>
        </CheckBox>
      </DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer>
    </Border>
    <Grid Grid.Row="3" Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel><TextBlock x:Name="StatusText" Text="準備中…" FontWeight="SemiBold"/><TextBlock x:Name="BackupText" Margin="0,4,0,0" Foreground="#6B7280"/></StackPanel>
      <Button Grid.Column="1" Content="再読み込み" Click="Reload_Click"/>
    </Grid>
  </Grid>
</Window>
