<Window x:Class="Shibori.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shibori" Height="590" Width="760" MinHeight="500" MinWidth="620"
        WindowStartupLocation="CenterScreen" Background="#F7F8FC">
  <Window.Resources>
    <Style TargetType="Button"><Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="18,10"/><Setter Property="Margin" Value="0,0,8,0"/></Style>
    <Style TargetType="ListViewItem"><Setter Property="Padding" Value="10,12"/><Setter Property="Margin" Value="0,0,0,6"/></Style>
  </Window.Resources>
  <Grid Margin="28">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <StackPanel>
      <TextBlock FontSize="30" FontWeight="Bold" Foreground="#1B1D2A" Text="Shibori"/>
      <TextBlock Margin="0,5,0,0" FontSize="15" Foreground="#636779" Text="VRを使う間だけ、不要なモニターを一時停止します"/>
    </StackPanel>
    <Border Grid.Row="1" Margin="0,24,0,14" Padding="14" Background="#E8EDFF" CornerRadius="8">
      <TextBlock TextWrapping="Wrap" Foreground="#35406C" Text="一時停止するモニターを選択してください。メインモニターは安全のため選択できません。"/>
    </Border>
    <ListView x:Name="MonitorList" Grid.Row="2" SelectionMode="Extended" BorderThickness="0" Background="Transparent" SelectionChanged="MonitorList_SelectionChanged">
      <ListView.ItemTemplate><DataTemplate>
        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
          <StackPanel><TextBlock FontWeight="SemiBold" FontSize="15" Text="{Binding Path=DeviceName}"/><TextBlock Margin="0,4,0,0" Foreground="#6B7082" Text="{Binding Path=Resolution}"/></StackPanel>
          <Border Grid.Column="1" Padding="9,4" CornerRadius="12" Background="#DDE3FA"><TextBlock Foreground="#3C4774" Text="{Binding Path=Role}"/></Border>
        </Grid>
      </DataTemplate></ListView.ItemTemplate>
    </ListView>
    <Grid Grid.Row="3" Margin="0,20,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel><TextBlock x:Name="StatusText" FontWeight="SemiBold" Text="読み込み中…"/><TextBlock x:Name="BackupText" Margin="0,4,0,0" Foreground="#73788A"/></StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <Button Content="再読み込み" Click="Reload_Click"/>
        <Button Content="元に戻す" Click="Restore_Click" IsEnabled="False" x:Name="RestoreButton"/>
        <Button Content="選択したモニターを一時停止" Background="#4D61D7" Foreground="White" Click="Pause_Click" x:Name="PauseButton"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
