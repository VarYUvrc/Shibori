<Window x:Class="Shibori.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shibori" Height="460" Width="650" MinHeight="360" MinWidth="540"
        WindowStartupLocation="CenterScreen" Background="#FAFAFA">
  <Window.Resources>
    <Style TargetType="CheckBox"><Setter Property="FontSize" Value="15"/><Setter Property="Padding" Value="8"/><Setter Property="Margin" Value="0,0,0,8"/></Style>
  </Window.Resources>
  <Grid Margin="28">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
    <Grid Margin="0,0,0,18">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel><TextBlock Text="Shibori" FontSize="28" FontWeight="SemiBold" Foreground="#202124"/><TextBlock Text="使わないモニターを一時停止" Margin="0,4,0,0" Foreground="#6B7280"/></StackPanel>
      <Button x:Name="InfoButton" Grid.Column="1" Content="ⓘ" FontSize="18" Width="32" Height="32" Padding="0" Margin="12,0,0,0" Click="About_Click" ToolTip="バージョン情報"/>
    </Grid>
    <Border Grid.Row="1" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="14" Background="White">
      <ScrollViewer VerticalScrollBarVisibility="Auto"><ItemsControl x:Name="MonitorList"><ItemsControl.ItemTemplate><DataTemplate>
        <CheckBox Tag="{Binding}" IsChecked="{Binding IsConnected}" Click="Monitor_Click">
          <Grid Width="530"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel><TextBlock Text="{Binding FriendlyName}" FontWeight="SemiBold"/><TextBlock Text="{Binding DeviceName}" Foreground="#9CA3AF" FontSize="12"/><TextBlock Text="{Binding Resolution}" Foreground="#6B7280" Margin="0,3,0,0"/><TextBlock Text="{Binding Status}" Foreground="#6B7280" Margin="0,3,0,0"/></StackPanel>
            <TextBlock Grid.Column="1" Text="{Binding Role}" Foreground="#6B7280" VerticalAlignment="Center"/>
          </Grid>
        </CheckBox>
      </DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer>
    </Border>
  </Grid>
</Window>
